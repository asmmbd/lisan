// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  password       String?        // Hashed password for credentials auth
  image          String?
  savedWords     SavedWord[]
  notes          Note[]
  searchHistory  SearchHistory[]
  callerRooms    Room[]         @relation("CallerRooms")
  receiverRooms  Room[]         @relation("ReceiverRooms")
  callInvites    CallInvite[]
  // Streak tracking
  streak         Int            @default(0)       // Current streak count
  lastStudyDate  DateTime?                       // Last day user studied
  longestStreak  Int            @default(0)     // Longest streak ever
  totalXP        Int            @default(0)       // Total XP points earned
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// User's saved Arabic words
model SavedWord {
  id           String     @id @default(cuid())
  wordId       String     // Reference to vocabulary word ID
  vocabularyId String?    // Optional link for migration
  vocabulary   Vocabulary? @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, wordId]) // Keep original unique constraint for now
}

// User's personal notes
model Note {
  id        String   @id @default(cuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// User's search history
model SearchHistory {
  id        String   @id @default(cuid())
  term      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Global vocabulary database
model Vocabulary {
  id                 String          @id @default(cuid())
  arabic             String
  bengali            String
  pronunciation      String
  example            String?
  exampleTranslation String?
  categorySlug       String          // Foreign key to Category.slug
  category           Category        @relation(fields: [categorySlug], references: [slug])
  savedBy            SavedWord[]
  sets               VocabularySet[] @relation("SetWords")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

// Vocabulary Categories (Metadata)
model Category {
  id        String       @id @default(cuid())
  slug      String       @unique // 'quranic', 'hadith', 'daily', etc.
  title     String
  icon      String?
  gradient  String?
  words     Vocabulary[]
  createdAt DateTime     @default(now())
}

// Vocabulary Sets (e.g., "Daily 100 words")
model VocabularySet {
  id          String       @id @default(cuid())
  title       String
  icon        String?
  total       Int          @default(0)
  category    String?      // Reference to category slug
  words       Vocabulary[] @relation("SetWords")
  createdAt   DateTime     @default(now())
}

// Video Call Matching Queue
model MatchingQueue {
  id        String   @id @default(cuid())
  userId    String   @unique
  socketId  String
  userName  String   @default("Guest")
  status    String   @default("waiting") // waiting, matched
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Active Video Call Matches
model ActiveMatch {
  id          String    @id @default(cuid())
  matchId     String    @unique
  user1Id     String
  user2Id     String
  channelName String
  roomName    String
  status      String    @default("waiting") // waiting, connected, ended
  createdAt   DateTime  @default(now())
  endedAt     DateTime?
  endedBy     String?
}

// WhatsApp-style Call Rooms
model Room {
  id          String       @id @default(cuid())
  roomId      String       @unique // Short unique ID for URL
  callerId    String
  caller      User         @relation("CallerRooms", fields: [callerId], references: [id])
  receiverId  String?
  receiver    User?        @relation("ReceiverRooms", fields: [receiverId], references: [id])
  status      String       @default("waiting") // waiting, active, ended
  channelName String
  createdAt   DateTime     @default(now())
  endedAt     DateTime?
  callInvites CallInvite[]
}

// Call Invitations for notifications
model CallInvite {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  callerId  String
  caller    User     @relation(fields: [callerId], references: [id])
  status    String   @default("pending") // pending, accepted, rejected, expired
  createdAt DateTime @default(now())
  expiresAt DateTime
}